# Server Configuration
PORT=3000
NODE_ENV=development

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Meta & WhatsApp Webhook Verification Token (inventa una clave para verificar con Meta)
META_VERIFY_TOKEN=originone_secure_token_2026

# Facebook & Instagram Page Access Token
META_PAGE_ACCESS_TOKEN=your_meta_page_access_token_here

# WhatsApp Cloud API Credentials
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# Destination WhatsApp Numbers for Appointment Notifications (separados por coma)
ADMIN_WHATSAPP_NUMBERS=528110653947,528120989813
