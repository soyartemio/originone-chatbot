# Server Configuration
PORT=3000
NODE_ENV=development

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Meta & WhatsApp Webhook Verification Token (inventa una clave para verificar con Meta)
META_VERIFY_TOKEN=originone_secure_token_2026

# Facebook & Instagram Page Access Token
META_PAGE_ACCESS_TOKEN=your_meta_page_access_token_here
INSTAGRAM_PAGE_ACCESS_TOKEN=your_instagram_page_access_token_here

# WhatsApp Cloud API Credentials
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# Destination WhatsApp Numbers for Appointment Notifications (separados por coma)
ADMIN_WHATSAPP_NUMBERS=528110653947,528120989813

# Cloudflare R2 privado para persistencia del CRM
# Crear un token de R2 limitado a Object Read & Write sobre un solo bucket.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=originone-crm
R2_CRM_OBJECT_KEY=crm/appointments.json
R2_AUTH_OBJECT_KEY=crm/auth.json

# Alternativa sin credenciales S3: gateway privado desplegado como Cloudflare Worker.
# En producción usa META_PAGE_ACCESS_TOKEN como fuente de firma si no se define otra.
CRM_GATEWAY_URL=https://originone-crm-storage.4nwq6cqmyj.workers.dev
# CRM_GATEWAY_SOURCE_SECRET=use_a_separate_existing_server_secret

# Acceso privado al CRM (genera valores aleatorios de 32 bytes o más)
AUTH_SESSION_SECRET=replace_with_a_random_64_character_secret
AUTH_SETUP_SECRET=replace_with_a_different_random_64_character_secret
AUTH_ORIGIN=http://localhost:3000
AUTH_RP_ID=localhost
AUTH_RP_NAME=Origin One CRM
AUTH_SESSION_TTL_SECONDS=28800
